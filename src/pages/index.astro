---
import Layout from "../layouts/Layout.astro";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What does this cost?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Most projects are $500–$2,000. Fixed price upfront — no hourly surprises.",
      },
    },
    {
      "@type": "Question",
      name: "I'm not technical. Is that a problem?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Nope. Most of my clients aren't. You know your business — I handle the tech.",
      },
    },
    {
      "@type": "Question",
      name: "What tools can you connect?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Monday, Asana, Slack, Google Workspace, HubSpot, Mailchimp, Calendly, Stripe, Airtable, Notion — if it has an API, I can probably connect it.",
      },
    },
    {
      "@type": "Question",
      name: "How fast can you deliver?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Something working within a week. Full launch in 2–4 weeks.",
      },
    },
    {
      "@type": "Question",
      name: "Can I maintain it after?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Yes. You own it, understand it, and can adjust it. Ongoing support available if you want it.",
      },
    },
  ],
};
---

<Layout>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <!-- ── NAV ── -->
  <header class="sticky top-0 z-50 bg-[#FAFAF9]/85 backdrop-blur-[16px] border-b border-[#E7E5E4]">
    <div class="max-w-[1000px] mx-auto px-7 py-3.5 flex items-center justify-between">
      <span class="font-[800] text-[17px] tracking-[-0.5px] text-[#1C1917]">Scott McFall</span>
      <nav aria-label="Main navigation" class="hidden sm:flex items-center gap-8">
        <a href="#problems" class="nav-link text-[13px] font-medium tracking-[0.3px] uppercase text-[#78716C] hover:text-[#1C1917] transition-colors">Problems</a>
        <a href="#services" class="nav-link text-[13px] font-medium tracking-[0.3px] uppercase text-[#78716C] hover:text-[#1C1917] transition-colors">Services</a>
        <a href="#work" class="nav-link text-[13px] font-medium tracking-[0.3px] uppercase text-[#78716C] hover:text-[#1C1917] transition-colors">Work</a>
      </nav>
      <a
        href="#contact"
        class="text-[13px] font-semibold bg-[#1C1917] text-[#FAFAF9] px-6 py-2.5 rounded-md hover:bg-[#44403C] transition-all tracking-[0.2px]"
      >
        Get in Touch
      </a>
    </div>
  </header>

  <main>
    <!-- ── HERO ── -->
    <section class="max-w-[1000px] mx-auto px-7 pt-[100px] pb-20">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-12">
        <!-- Left: copy -->
        <div class="lg:max-w-[540px]">
          <p class="fade-up text-[12px] font-bold tracking-[2.5px] uppercase text-[#4A6741] mb-6" style="animation-delay: 0ms">Workflow & Growth Consultant</p>
          <h1 class="fade-up text-[clamp(36px,5.5vw,60px)] font-[900] leading-[1.05] tracking-[-2px] text-[#1C1917] mb-6" style="animation-delay: 80ms">
            Small team.<br>Big backlog.<br><span class="text-[#4A6741]">I fix that.</span>
          </h1>
          <p class="fade-up text-[17px] text-[#78716C] mb-9 max-w-[480px] leading-[1.65]" style="animation-delay: 160ms">
            I connect your tools, automate the busywork, and build pages that capture leads — so you stop losing time and money to things a human shouldn't be doing.
          </p>
          <div class="fade-up flex gap-3 flex-wrap" style="animation-delay: 240ms">
            <a href="#contact" class="inline-block bg-[#1C1917] text-[#FAFAF9] font-semibold px-6 py-2.5 rounded-md hover:bg-[#44403C] transition-all text-[13px] tracking-[0.2px]">
              Book a Free Consultation
            </a>
            <a href="#problems" class="inline-block bg-transparent text-[#1C1917] font-semibold px-6 py-2.5 rounded-md border-[1.5px] border-[#D6D3D1] hover:border-[#1C1917] transition-all text-[13px] tracking-[0.2px]">
              See If This Is You
            </a>
          </div>
        </div>

        <!-- Right: savings proof card -->
        <div class="fade-up lg:max-w-[340px] w-full" style="animation-delay: 300ms">
          <div class="bg-[#F5F5F4] border border-[#E7E5E4] rounded-2xl p-7 relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-[3px] bg-[#4A6741]"></div>
            <p class="text-[11px] font-bold tracking-[2px] uppercase text-[#4A6741] mb-4">Real Client Results</p>
            <p class="text-[40px] font-[900] tracking-[-1.5px] text-[#1C1917] leading-none mb-1">$21k+</p>
            <p class="text-[14px] text-[#78716C] mb-5">saved per year</p>
            <div class="space-y-3 pt-4 border-t border-[#E7E5E4]">
              <div class="flex items-baseline justify-between">
                <span class="text-[13px] text-[#57534E]">Hours reclaimed weekly</span>
                <span class="text-[15px] font-[800] text-[#1C1917]">15+</span>
              </div>
              <div class="flex items-baseline justify-between">
                <span class="text-[13px] text-[#57534E]">Tools replaced</span>
                <span class="text-[15px] font-[800] text-[#1C1917]">5 → 1</span>
              </div>
              <div class="flex items-baseline justify-between">
                <span class="text-[13px] text-[#57534E]">Manual processes cut</span>
                <span class="text-[15px] font-[800] text-[#1C1917]">80%</span>
              </div>
            </div>
            <p class="text-[11px] text-[#A8A29E] mt-4 italic">Based on Formation Consulting engagement</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── TRUST BAR ── -->
    <section class="border-t border-b border-[#E7E5E4] bg-[#F5F5F4] py-[18px]">
      <div class="max-w-[1000px] mx-auto px-7 text-center">
        <p class="text-[13px] text-[#A8A29E] font-medium">
          Worked with <strong class="text-[#57534E] font-semibold">Lewis Howes</strong>,
          <strong class="text-[#57534E] font-semibold">JJ Virgin</strong>,
          and growing teams in media, health & education.
        </p>
      </div>
    </section>

    <!-- ── PAIN POINTS ── -->
    <section id="problems" class="bg-[#F0F4EE] border-b border-[#E7E5E4] py-20">
      <div class="max-w-[1000px] mx-auto px-7">
        <p class="text-[12px] font-bold tracking-[2.5px] uppercase text-[#4A6741] mb-3">Sound Familiar?</p>
        <h2 class="text-[36px] font-[800] tracking-[-1px] text-[#1C1917] mb-12">The stuff nobody has time to fix.</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-[#D6D3D1] border border-[#D6D3D1] rounded-xl overflow-hidden">
          <div class="cell-fade bg-white/85 p-8 transition-all duration-300 hover:bg-white hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(74,103,65,0.1)] hover:z-10 hover:relative group" style="animation-delay: 0ms">
            <h3 class="text-[15px] font-bold mb-2 leading-tight group-hover:text-[#4A6741] transition-colors">Your tools don't talk to each other</h3>
            <p class="text-[13px] text-[#78716C] leading-relaxed">Same update in Monday, Slack, your spreadsheet, and your CRM. Four times. Every day.</p>
          </div>
          <div class="cell-fade bg-white/85 p-8 transition-all duration-300 hover:bg-white hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(74,103,65,0.1)] hover:z-10 hover:relative group" style="animation-delay: 80ms">
            <h3 class="text-[15px] font-bold mb-2 leading-tight group-hover:text-[#4A6741] transition-colors">Copy-paste is your "integration"</h3>
            <p class="text-[13px] text-[#78716C] leading-relaxed">Export, reformat, email. Hours gone, and one mistake means starting over.</p>
          </div>
          <div class="cell-fade bg-white/85 p-8 transition-all duration-300 hover:bg-white hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(74,103,65,0.1)] hover:z-10 hover:relative group" style="animation-delay: 160ms">
            <h3 class="text-[15px] font-bold mb-2 leading-tight group-hover:text-[#4A6741] transition-colors">Leads fall through the cracks</h3>
            <p class="text-[13px] text-[#78716C] leading-relaxed">Someone fills out your form and then... nothing. No sequence, no tracking.</p>
          </div>
          <div class="cell-fade bg-white/85 p-8 transition-all duration-300 hover:bg-white hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(74,103,65,0.1)] hover:z-10 hover:relative group" style="animation-delay: 240ms">
            <h3 class="text-[15px] font-bold mb-2 leading-tight group-hover:text-[#4A6741] transition-colors">You need a landing page yesterday</h3>
            <p class="text-[13px] text-[#78716C] leading-relaxed">You know you need a better funnel. Agency quotes are $5k+. You just need something that works.</p>
          </div>
          <div class="cell-fade bg-white/85 p-8 transition-all duration-300 hover:bg-white hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(74,103,65,0.1)] hover:z-10 hover:relative group" style="animation-delay: 320ms">
            <h3 class="text-[15px] font-bold mb-2 leading-tight group-hover:text-[#4A6741] transition-colors">Someone's doing 10 hrs/week of busywork</h3>
            <p class="text-[13px] text-[#78716C] leading-relaxed">Formatting reports, sending reminders, updating statuses. It shouldn't be done by a human.</p>
          </div>
          <div class="cell-fade bg-white/85 p-8 transition-all duration-300 hover:bg-white hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(74,103,65,0.1)] hover:z-10 hover:relative group" style="animation-delay: 400ms">
            <h3 class="text-[15px] font-bold mb-2 leading-tight group-hover:text-[#4A6741] transition-colors">You don't know where to start</h3>
            <p class="text-[13px] text-[#78716C] leading-relaxed">You've heard of Zapier, Make, n8n. Who has time to learn them when you're already stretched?</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── SERVICES ── -->
    <section id="services" class="bg-[#F5F5F4] border-b border-[#E7E5E4] py-20">
      <div class="max-w-[1000px] mx-auto px-7">
        <p class="text-[12px] font-bold tracking-[2.5px] uppercase text-[#4A6741] mb-3">What I Do</p>
        <h2 class="text-[36px] font-[800] tracking-[-1px] text-[#1C1917] mb-2">Two things. Done well.</h2>
        <p class="text-[15px] text-[#78716C] mb-12">Most of what's slowing your team down falls into one of these.</p>
        <div class="grid sm:grid-cols-2 gap-6">
          <div class="scroll-fade bg-[#FAFAF9] rounded-xl p-9 border border-[#E7E5E4] relative hover:shadow-[0_12px_40px_rgba(0,0,0,0.06)] transition-shadow">
            <div class="absolute top-4 right-6 text-[72px] font-[900] text-[#E7E5E4] leading-none tracking-[-3px]">01</div>
            <h3 class="text-[20px] font-[800] tracking-[-0.5px] mb-2.5">Integrations & Automation</h3>
            <p class="text-[14px] text-[#78716C] mb-5 leading-relaxed">I connect your existing tools and eliminate the repetitive work eating your team's week.</p>
            <ul class="space-y-1">
              <li class="text-[13px] text-[#57534E] pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[9px] before:w-1.5 before:h-1.5 before:rounded-full before:bg-[#4A6741]">Monday → Slack notifications</li>
              <li class="text-[13px] text-[#57534E] pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[9px] before:w-1.5 before:h-1.5 before:rounded-full before:bg-[#4A6741]">Calendar → Asana task creation</li>
              <li class="text-[13px] text-[#57534E] pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[9px] before:w-1.5 before:h-1.5 before:rounded-full before:bg-[#4A6741]">Form fills → CRM + email sequence</li>
              <li class="text-[13px] text-[#57534E] pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[9px] before:w-1.5 before:h-1.5 before:rounded-full before:bg-[#4A6741]">Raw data → auto-formatted reports</li>
              <li class="text-[13px] text-[#57534E] pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[9px] before:w-1.5 before:h-1.5 before:rounded-full before:bg-[#4A6741]">Custom API connections</li>
            </ul>
          </div>
          <div class="scroll-fade bg-[#FAFAF9] rounded-xl p-9 border border-[#E7E5E4] relative hover:shadow-[0_12px_40px_rgba(0,0,0,0.06)] transition-shadow" style="animation-delay: 80ms">
            <div class="absolute top-4 right-6 text-[72px] font-[900] text-[#E7E5E4] leading-none tracking-[-3px]">02</div>
            <h3 class="text-[20px] font-[800] tracking-[-0.5px] mb-2.5">Landing Pages & Funnels</h3>
            <p class="text-[14px] text-[#78716C] mb-5 leading-relaxed">Fast, focused pages that turn visitors into leads. No bloated WordPress — just pages built to convert.</p>
            <ul class="space-y-1">
              <li class="text-[13px] text-[#57534E] pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[9px] before:w-1.5 before:h-1.5 before:rounded-full before:bg-[#4A6741]">Lead capture with email integration</li>
              <li class="text-[13px] text-[#57534E] pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[9px] before:w-1.5 before:h-1.5 before:rounded-full before:bg-[#4A6741]">Quiz & calculator lead magnets</li>
              <li class="text-[13px] text-[#57534E] pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[9px] before:w-1.5 before:h-1.5 before:rounded-full before:bg-[#4A6741]">Sales funnels with auto follow-up</li>
              <li class="text-[13px] text-[#57534E] pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[9px] before:w-1.5 before:h-1.5 before:rounded-full before:bg-[#4A6741]">A/B testing & conversion optimization</li>
              <li class="text-[13px] text-[#57534E] pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[9px] before:w-1.5 before:h-1.5 before:rounded-full before:bg-[#4A6741]">SEO-optimized pages that rank</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ── ROI CALCULATOR ── -->
    <section class="border-b border-[#E7E5E4] bg-[#1C1917] text-[#FAFAF9]">
      <div class="max-w-[1000px] mx-auto px-7 py-20">
        <p class="text-[12px] font-bold tracking-[2.5px] uppercase text-[#4A6741] mb-3">Calculator</p>
        <h2 class="text-[36px] font-[800] tracking-[-1px] text-[#FAFAF9] mb-2">What's the busywork costing you?</h2>
        <p class="text-[15px] text-[#A8A29E] mb-9">Add the tasks eating your time. See the real number.</p>

        <div class="grid sm:grid-cols-2 gap-4 mb-5">
          <div class="bg-[#292524] rounded-[10px] p-6 border border-[#44403C]">
            <label for="hourlyRate" class="block text-[13px] font-semibold text-[#D6D3D1] mb-2.5">Hourly rate (yours or your team member's)</label>
            <div class="flex items-center gap-2">
              <span class="text-[18px] text-[#A8A29E]">$</span>
              <input
                type="number"
                id="hourlyRate"
                value="50"
                min="10"
                max="500"
                step="5"
                class="text-[28px] font-[800] text-[#FAFAF9] bg-transparent border-0 border-b-2 border-[#4A6741] focus:outline-none w-[90px] font-sans"
              />
              <span class="text-[18px] text-[#A8A29E]">/ hr</span>
            </div>
          </div>
          <button
            id="addTaskBtn"
            class="bg-[#292524] border border-[#44403C] text-[#D6D3D1] font-semibold text-[15px] rounded-[10px] p-6 hover:bg-[#44403C] hover:text-[#FAFAF9] transition-all cursor-pointer"
          >
            + Add a Task
          </button>
        </div>

        <!-- Task Presets -->
        <div id="taskPresets" class="hidden bg-[#292524] border border-[#44403C] rounded-[10px] p-6 mb-5">
          <p class="text-[13px] font-semibold text-[#D6D3D1] mb-3">Pick a common task or add your own:</p>
          <div class="grid sm:grid-cols-2 gap-2">
            <button class="preset-btn text-left px-3.5 py-2.5 rounded-md bg-[#44403C] text-[#E7E5E4] hover:bg-[#4A6741] hover:text-white transition-all text-[13px] cursor-pointer" data-task="Copying data between tools">Copying data between tools</button>
            <button class="preset-btn text-left px-3.5 py-2.5 rounded-md bg-[#44403C] text-[#E7E5E4] hover:bg-[#4A6741] hover:text-white transition-all text-[13px] cursor-pointer" data-task="Updating status across platforms">Updating status across platforms</button>
            <button class="preset-btn text-left px-3.5 py-2.5 rounded-md bg-[#44403C] text-[#E7E5E4] hover:bg-[#4A6741] hover:text-white transition-all text-[13px] cursor-pointer" data-task="Manual follow-up emails">Manual follow-up emails</button>
            <button class="preset-btn text-left px-3.5 py-2.5 rounded-md bg-[#44403C] text-[#E7E5E4] hover:bg-[#4A6741] hover:text-white transition-all text-[13px] cursor-pointer" data-task="Formatting & sending reports">Formatting & sending reports</button>
            <button class="preset-btn text-left px-3.5 py-2.5 rounded-md bg-[#44403C] text-[#E7E5E4] hover:bg-[#4A6741] hover:text-white transition-all text-[13px] cursor-pointer" data-task="Social media scheduling">Social media scheduling</button>
            <button class="preset-btn text-left px-3.5 py-2.5 rounded-md bg-[#44403C] text-[#E7E5E4] hover:bg-[#4A6741] hover:text-white transition-all text-[13px] cursor-pointer" data-task="Invoice processing & tracking">Invoice processing & tracking</button>
            <button class="preset-btn text-left px-3.5 py-2.5 rounded-md bg-[#44403C] text-[#E7E5E4] hover:bg-[#4A6741] hover:text-white transition-all text-[13px] cursor-pointer" data-task="Meeting notes & task assignment">Meeting notes & task assignment</button>
            <button class="preset-btn text-left px-3.5 py-2.5 rounded-md bg-[#44403C] text-[#E7E5E4] hover:bg-[#4A6741] hover:text-white transition-all text-[13px] cursor-pointer" data-task="Lead follow-up & CRM updates">Lead follow-up & CRM updates</button>
          </div>
          <div class="mt-3.5 pt-3.5 border-t border-[#44403C]">
            <input
              type="text"
              id="customTaskInput"
              placeholder="Or type your own..."
              class="w-full px-3 py-2.5 rounded-md border border-[#44403C] bg-[#292524] text-[13px] text-[#FAFAF9] placeholder-[#78716C] focus:outline-none focus:border-[#4A6741] mb-2"
            />
            <button id="addCustomTaskBtn" class="w-full py-2.5 rounded-md bg-[#4A6741] text-white font-semibold text-[13px] hover:bg-[#3A5233] transition-colors cursor-pointer">Add Custom Task</button>
          </div>
        </div>

        <!-- Task List -->
        <div id="taskList" class="space-y-2.5 mb-5"></div>

        <!-- Results Panel -->
        <div id="resultsPanel" class="hidden bg-[#292524] border border-[#44403C] rounded-xl p-7">
          <div class="grid sm:grid-cols-2 gap-5 mb-5">
            <div>
              <p class="text-[12px] text-[#A8A29E] mb-1 uppercase tracking-[1px] font-semibold">Weekly time spent</p>
              <p class="text-[32px] font-[800] text-[#FAFAF9]" id="totalHours">0</p>
              <p class="text-[12px] text-[#78716C] mt-0.5" id="weekEquivalent"></p>
            </div>
            <div>
              <p class="text-[12px] text-[#A8A29E] mb-1 uppercase tracking-[1px] font-semibold">Annual cost</p>
              <p class="text-[32px] font-[800] text-[#FAFAF9]" id="annualCost">$0</p>
            </div>
          </div>

          <div class="border-t border-[#44403C] pt-5">
            <div class="flex items-center justify-between mb-1.5">
              <p class="text-[12px] text-[#A8A29E] uppercase tracking-[1px] font-semibold">Potential savings</p>
              <span class="text-[11px] font-bold bg-[#4A6741] text-white px-2.5 py-0.5 rounded-[10px]">~70% time reduction</span>
            </div>
            <p class="text-[12px] text-[#78716C] mb-3">Most automations save 60–80%. You still review — the heavy lifting is handled.</p>
            <div class="flex items-center gap-2 mb-3">
              <label for="timeHorizon" class="text-[13px] font-semibold text-[#E7E5E4]">Over</label>
              <select id="timeHorizon" class="bg-[#44403C] border border-[#57534E] rounded px-2.5 py-1 text-[13px] font-semibold text-[#F5F5F4] focus:outline-none">
                <option value="1">1 year</option>
                <option value="3" selected>3 years</option>
                <option value="5">5 years</option>
              </select>
            </div>
            <p class="text-[40px] font-[900] text-[#4A6741] mb-1 tracking-[-1px]" id="totalSavings">$0</p>
            <p class="text-[13px] text-[#A8A29E]" id="timeSaved">Plus 0 hours back</p>
          </div>

          <div class="mt-4 pt-4 border-t border-[#44403C]">
            <p class="text-[12px] text-[#A8A29E] mb-2 uppercase tracking-[1px] font-semibold">That's enough to:</p>
            <div id="insights" class="space-y-1"></div>
          </div>

          <a
            href="#contact"
            class="mt-5 block w-full bg-[#4A6741] text-white font-semibold px-6 py-3.5 rounded-md hover:bg-[#3A5233] transition-colors text-center text-[13px]"
          >
            Let's automate one of these →
          </a>
        </div>
      </div>
    </section>

    <!-- ── WORK ── -->
    <section id="work" class="border-b border-[#E7E5E4] py-20">
      <div class="max-w-[1000px] mx-auto px-7">
        <p class="text-[12px] font-bold tracking-[2.5px] uppercase text-[#4A6741] mb-3">Recent Work</p>
        <h2 class="text-[36px] font-[800] tracking-[-1px] text-[#1C1917] mb-12">Real projects. Real outcomes.</h2>

        <div class="grid sm:grid-cols-2 gap-5">
          <!-- Featured: Lewis Howes -->
          <div class="scroll-fade sm:col-span-2 border border-[#E7E5E4] rounded-[10px] p-7 bg-[#FAFAF9] hover:border-[#4A6741] transition-all">
            <p class="text-[11px] font-bold tracking-[2px] uppercase text-[#4A6741] mb-2">Workflow Automation</p>
            <h3 class="text-[17px] font-bold tracking-[-0.3px] mb-2">Post-Production Automation — Lewis Howes / School of Greatness</h3>
