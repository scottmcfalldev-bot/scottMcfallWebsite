  <script>
    // ROI Calculator Logic
    let tasks: { id: number; name: string; hours: number }[] = [];
    let taskIdCounter = 0;

    const hourlyRateInput = document.getElementById('hourlyRate') as HTMLInputElement;
    const addTaskBtn = document.getElementById('addTaskBtn')!;
    const taskPresets = document.getElementById('taskPresets')!;
    const taskList = document.getElementById('taskList')!;
    const resultsPanel = document.getElementById('resultsPanel')!;
    const customTaskInput = document.getElementById('customTaskInput') as HTMLInputElement;
    const addCustomTaskBtn = document.getElementById('addCustomTaskBtn')!;
    const timeHorizonSelect = document.getElementById('timeHorizon') as HTMLSelectElement;

    addTaskBtn.addEventListener('click', () => {
      taskPresets.classList.toggle('hidden');
    });

    document.querySelectorAll('.preset-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        addTask((btn as HTMLElement).dataset.task!);
        taskPresets.classList.add('hidden');
      });
    });

    addCustomTaskBtn.addEventListener('click', () => {
      const taskName = customTaskInput.value.trim();
      if (taskName) {
        addTask(taskName);
        customTaskInput.value = '';
        taskPresets.classList.add('hidden');
      }
    });

    customTaskInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') addCustomTaskBtn.click();
    });

    function addTask(name: string) {
      const taskId = taskIdCounter++;
      tasks.push({ id: taskId, name, hours: 2 });

      const taskCard = document.createElement('div');
      taskCard.className = 'fade-up bg-[#292524] border border-[#44403C] rounded-[10px] px-5 py-[18px] flex items-center justify-between gap-4';
      taskCard.style.animationDelay = '0ms';
      taskCard.dataset.taskId = String(taskId);

      taskCard.innerHTML = `
        <div class="flex-1">
          <p class="font-semibold text-[14px] text-[#F5F5F4] mb-1.5">${name}</p>
          <div class="flex items-center gap-2">
            <input type="number" value="2" min="0.5" max="40" step="0.5"
              class="task-hours w-14 px-2 py-1 border border-[#57534E] rounded bg-[#44403C] text-[13px] text-[#F5F5F4] focus:outline-none focus:border-[#4A6741]"
              data-task-id="${taskId}" />
            <span class="text-[12px] text-[#A8A29E]">hrs/week</span>
          </div>
        </div>
        <button class="remove-task text-[#78716C] hover:text-red-400 transition-colors text-[16px] cursor-pointer" data-task-id="${taskId}">✕</button>
      `;

      taskList.appendChild(taskCard);

      taskCard.querySelector('.task-hours')!.addEventListener('input', (e) => {
        updateTaskHours(taskId, parseFloat((e.target as HTMLInputElement).value) || 0);
      });

      taskCard.querySelector('.remove-task')!.addEventListener('click', () => {
        removeTask(taskId);
      });

      calculate();
    }

    function updateTaskHours(taskId: number, hours: number) {
      const task = tasks.find(t => t.id === taskId);
      if (task) {
        task.hours = hours;
        calculate();
      }
    }

    function removeTask(taskId: number) {
      tasks = tasks.filter(t => t.id !== taskId);
      const taskCard = document.querySelector(`[data-task-id="${taskId}"]`) as HTMLElement;
      if (taskCard && taskCard.classList.contains('bg-[#292524]')) {
        taskCard.style.opacity = '0';
        taskCard.style.transform = 'translateX(-16px)';
        taskCard.style.transition = 'all 0.2s';
        setTimeout(() => taskCard.remove(), 200);
      }
      calculate();
    }

    function calculate() {
      if (tasks.length === 0) {
        resultsPanel.classList.add('hidden');
        return;
      }

      resultsPanel.classList.remove('hidden');

      const hourlyRate = parseFloat(hourlyRateInput.value) || 0;
      const totalHoursPerWeek = tasks.reduce((sum, task) => sum + task.hours, 0);
      const hoursPerYear = totalHoursPerWeek * 52;
      const annualCost = hoursPerYear * hourlyRate;

      const automationEfficiency = 0.70;
      const hoursSavedPerYear = hoursPerYear * automationEfficiency;
      const annualSavings = annualCost * automationEfficiency;

      const timeHorizon = parseInt(timeHorizonSelect.value) || 3;
      const totalSavings = annualSavings * timeHorizon;
      const totalHoursSaved = hoursSavedPerYear * timeHorizon;

      document.getElementById('totalHours')!.textContent = totalHoursPerWeek.toFixed(1) + ' hrs';

      const pct = ((totalHoursPerWeek / 40) * 100).toFixed(0);
      document.getElementById('weekEquivalent')!.textContent = Number(pct) > 1 ? `${pct}% of a full-time role` : '';

      document.getElementById('annualCost')!.textContent = '$' + annualCost.toLocaleString('en-US', { maximumFractionDigits: 0 });
      document.getElementById('totalSavings')!.textContent = '$' + totalSavings.toLocaleString('en-US', { maximumFractionDigits: 0 });
      document.getElementById('timeSaved')!.textContent = `Plus ${Math.round(totalHoursSaved).toLocaleString()} hours back`;

      const insights: string[] = [];
      const weeksOfWork = Math.floor(totalHoursSaved / 40);
      if (weeksOfWork >= 1) insights.push(`✓ Free up ${weeksOfWork} full work week${weeksOfWork > 1 ? 's' : ''}`);

      const monthlyProjectEquiv = Math.floor(totalHoursSaved / 160);
      if (monthlyProjectEquiv >= 1) insights.push(`✓ Take on ${monthlyProjectEquiv} extra project${monthlyProjectEquiv > 1 ? 's' : ''}`);

      if (totalSavings >= 10000) insights.push(`✓ Reinvest $${Math.round(totalSavings / 1000)}k into growth`);

      insights.push(`✓ Eliminate ${Math.round(hoursSavedPerYear)} hrs/year of repetitive work`);

      document.getElementById('insights')!.innerHTML = insights.map(i =>
        `<div class="text-[13px] text-[#D6D3D1] py-0.5">${i}</div>`
      ).join('');
    }

    hourlyRateInput.addEventListener('input', calculate);
    timeHorizonSelect.addEventListener('change', calculate);
  </script>
