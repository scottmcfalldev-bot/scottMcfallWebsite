---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Scott McFall — Workflow & Growth Consultant for Small Teams",
  description = "I connect your tools, automate the busywork, and build landing pages that capture leads. Integrations, automation, and funnels for small teams.",
  ogImage = "/profile.svg",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site).toString();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "Scott McFall",
  url: "https://scottmcfall.com",
  description,
  founder: {
    "@type": "Person",
    name: "Scott McFall",
    jobTitle: "Workflow & Growth Consultant",
  },
  serviceType: ["Workflow Automation", "Business Integrations", "Landing Page Development", "Lead Funnel Optimization"],
  areaServed: "US",
  sameAs: [
    "https://github.com/scottmcfalldev-bot",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Scott McFall" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#4A6741" />

    <!-- Open Graph -->
    <meta property="og:site_name" content="Scott McFall" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:alt" content="Scott McFall — Workflow & Growth Consultant for Small Teams" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content="Scott McFall — Workflow & Growth Consultant for Small Teams" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  </head>
  <body>
    <slot />
  </body>
</html>
